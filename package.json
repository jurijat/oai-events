{
  "name": "openapi-events-site",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "preview:webkit": "playwright open --browser=webkit http://localhost:3000",
    "preview:iphone": "playwright open --device=\"iPhone 14 Pro\" http://localhost:3000",
    "preview:iphone17": "playwright open --browser=webkit --viewport-size=440,956 --user-agent=\"Mozilla/5.0 (iPhone; CPU iPhone OS 26_0 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/26.0 Mobile/15E148 Safari/604.1\" http://localhost:3000",
    "preview:ipad": "playwright open --device=\"iPad Pro 11\" http://localhost:3000"
  },
  "dependencies": {
    "clsx": "^2.0.0",
    "js-yaml": "^4.1.1",
    "next": "^15.0.0",
    "next-themes": "^0.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.5.9",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0"
  }
}
